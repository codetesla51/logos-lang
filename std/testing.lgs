let passed = 0
let failed = 0
let total = 0
let suiteNames = []
let assert = fn(name, got, expected) {
    total = total + 1
    if toStr(got) == toStr(expected) {
        passed = passed + 1
    } else {
        print(colorRed("--- FAIL: ") + name + " (got=" + toStr(got) + " expected=" + toStr(expected) + ")")
        failed = failed + 1
    }
}
let suite = fn(name, func) {
    push(suiteNames, name)
    func()
}
let summary = fn() {
    let names = ""
    let i = 0
    for i < len(suiteNames) {
        if i > 0 {
            names = names + ", "
        }
        names = names + suiteNames[i]
        i = i + 1
    }
    if failed > 0 {
        print(colorRed("FAIL"))
        print(colorRed("failed: ") + toStr(failed) + "/" + toStr(total))
        exit(1)
    } else {
        print(colorGreen("ok") + "    " + names + "    " + toStr(total) + " tests passed")
    }
}
